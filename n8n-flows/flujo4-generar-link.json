        "authentication": "none",
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({ chat_id: '7790296286', text: '🔗 *LINK DE MENÚ GENERADO — La Cabaña*\\n\\n👤 ' + $('Generar token único').first().json.nombre + '\\n📱 ' + $('Generar token único').first().json.telefono + '\\n🎊 ' + $('Generar token único').first().json.tipo_evento + '\\n📅 ' + $('Generar token único').first().json.fecha_evento + '\\n📦 ' + $('Generar token único').first().json.paquete_asignado + '\\n\\n🔗 Link para el cliente:\\n' + $('Generar token único').first().json.link + '\\n\\n📋 Cópialo y envíalo por WhatsApp.', parse_mode: 'Markdown' }) }}",
        "options": {}
      },
