        "jsCode": "const data = $input.first().json;\nconst ahora = new Date();\nconst token = 'LC-' + ahora.getTime() + '-' + Math.random().toString(36).substr(2, 6).toUpperCase();\nconst link = 'https://n8n.lacabanaeventos.com/webhook/seleccion?token=' + token;\n\nreturn [{ json: {\n  token,\n  link,\n  nombre: data['Nombre completo del cliente'] || '',\n  email: data['Email del cliente'] || '',\n  telefono: data['Teléfono del cliente'] || '',\n  fecha_evento: data['Fecha del evento'] || '',\n  tipo_evento: data['Tipo de evento'] || '',\n  paquete_asignado: data['Paquete contratado'] || '',\n  status: 'pendiente',\n  fecha_generacion: ahora.toLocaleString('es-MX', { timeZone: 'America/Mexico_City' }),\n  menu_elegido: '',\n  opcion_elegida: '',\n  num_invitados: '',\n  cocteleria: '',\n  cerveza_barril: '',\n  dietas_especiales: '',\n  notas_cliente: '',\n  fecha_seleccion: ''\n}}];"
      },
